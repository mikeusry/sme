---
/**
 * Contact Page
 *
 * Contact form, business info, and location
 * Content source: crawled + business-info.json
 * Route: /contact
 */

import MainLayout from '../layouts/MainLayout.astro';
import { business } from '../lib/business';
import { getSocialPlatformsArray, socialIconPaths } from '../lib/social';

const socialLinks = getSocialPlatformsArray();

// Platform-specific hover colors for the contact page social section
const platformHoverColors: Record<string, string> = {
  facebook: 'hover:text-blue-600',
  instagram: 'hover:text-pink-600',
  youtube: 'hover:text-red-600',
  tiktok: 'hover:text-black',
};

const googleMapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(business.address.full)}`;
const googleMapsEmbed = `https://www.google.com/maps?q=${business.geo.lat},${business.geo.lng}&z=15&output=embed`;
---

<MainLayout
  title="Contact Us | Soul Miner's Eden | Athens GA"
  description="Contact Soul Miner's Eden for landscape supplies, delivery questions, or bulk orders. Located in Bogart, GA serving the Athens area. Call (706) 613-4415."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-500 to-primary-600 text-white py-16">
    <div class="container-custom">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">
          Contact Us
        </h1>
        <p class="text-xl text-primary-100">
          Need to speak to someone on our team? We're here to help! You won't get an answering service—someone from our team here in Athens, Georgia will be on the other line ready to offer you the kind of service you deserve.
        </p>
      </div>
    </div>
  </section>

  <div class="container-custom py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <div>
        <h2 class="text-2xl font-display font-bold text-warm-900 mb-6">
          Send Us a Message
        </h2>

        <form class="space-y-6" action="#" method="POST" id="contact-form">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-warm-700 mb-2">
                Your Name *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="input w-full"
                placeholder="John Smith"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-warm-700 mb-2">
                Phone Number
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="input w-full"
                placeholder="(706) 555-1234"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-warm-700 mb-2">
              Email Address *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="input w-full"
              placeholder="john@example.com"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-warm-700 mb-2">
              What can we help you with?
            </label>
            <select id="subject" name="subject" class="select w-full">
              <option value="">Select a topic...</option>
              <option value="product-inquiry">Product Inquiry</option>
              <option value="delivery">Delivery Questions</option>
              <option value="quote">Request a Quote</option>
              <option value="contractor">Contractor Program</option>
              <option value="land-management">Land Management Services</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-warm-700 mb-2">
              Message *
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="input w-full resize-none"
              placeholder="Tell us how we can help..."
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full text-lg py-4">
            Send Message
          </button>
        </form>

        <p class="mt-4 text-sm text-warm-500">
          We typically respond within 24 hours during business days.
        </p>
      </div>

      <!-- Contact Info -->
      <div class="space-y-8">
        <!-- Quick Contact -->
        <div class="bg-primary-50 border border-primary-200 rounded-xl p-6">
          <h2 class="text-2xl font-display font-bold text-warm-900 mb-6">
            Quick Contact
          </h2>

          <div class="space-y-4">
            <!-- Phone -->
            <a
              href={business.phoneHref}
              class="flex items-start gap-4 p-4 bg-white rounded-lg border border-primary-200 hover:border-primary-400 transition-colors group"
            >
              <div class="w-12 h-12 bg-accent-100 rounded-full flex items-center justify-center flex-shrink-0 group-hover:bg-accent-200 transition-colors">
                <svg class="w-6 h-6 text-accent-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-warm-900 text-lg">{business.phone}</p>
                <p class="text-warm-600 text-sm">Call or text anytime</p>
              </div>
            </a>

            <!-- Email — use the form above instead of mailto -->
            <a
              href="#contact-form"
              class="flex items-start gap-4 p-4 bg-white rounded-lg border border-primary-200 hover:border-primary-400 transition-colors group"
            >
              <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0 group-hover:bg-primary-200 transition-colors">
                <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-warm-900">{business.email}</p>
                <p class="text-warm-600 text-sm">Use the form above to reach us</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Location & Hours -->
        <div class="bg-warm-50 border border-warm-200 rounded-xl p-6">
          <h3 class="text-xl font-bold text-warm-900 mb-4">Location & Hours</h3>

          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-600 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="font-medium text-warm-900">{business.address.street}</p>
                <p class="text-warm-600">{business.address.city}, {business.address.state} {business.address.zip}</p>
                <a
                  href={googleMapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary-600 hover:text-primary-700 text-sm font-medium mt-1 inline-block"
                >
                  Get Directions →
                </a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-600 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-warm-900">Business Hours</p>
                <p class="text-warm-600">{business.hours.display}</p>
                <p class="text-warm-500 text-sm">Sunday: Closed</p>
              </div>
            </div>
          </div>

          <!-- Map embed -->
          <div class="mt-6 rounded-lg overflow-hidden h-48">
            <iframe
              src={googleMapsEmbed}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Map showing ${business.address.full}`}
            ></iframe>
          </div>
        </div>

        <!-- Social & Reviews -->
        <div class="bg-white border border-warm-200 rounded-xl p-6">
          <div class="flex items-center gap-2 mb-4">
            <div class="flex text-yellow-400">
              {Array(5).fill(0).map((_, i) => (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="font-bold text-warm-900">4.9</span>
            <span class="text-warm-500">(47 reviews)</span>
          </div>

          <div class="flex gap-4">
            {socialLinks.map(platform => (
              <a
                href={platform.url}
                target="_blank"
                rel="noopener noreferrer"
                class={`text-warm-400 ${platformHoverColors[platform.key] || 'hover:text-primary-400'} transition-colors`}
                aria-label={platform.ariaLabel}
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d={socialIconPaths[platform.key]} />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section -->
    <section id="faq" class="mt-20 bg-warm-50 rounded-2xl p-8">
      <h2 class="text-3xl font-display font-bold text-warm-900 mb-8 text-center">
        Frequently Asked Questions
      </h2>

      <div class="max-w-3xl mx-auto space-y-4">
        <div class="bg-warm-50 border border-secondary-200 rounded-lg p-6">
          <h3 class="font-bold text-warm-900 mb-2">What areas do you deliver to?</h3>
          <p class="text-warm-600">We deliver throughout the Athens-Clarke County area and surrounding communities within approximately 40 miles of our farm in Bogart, GA.</p>
        </div>

        <div class="bg-warm-50 border border-secondary-200 rounded-lg p-6">
          <h3 class="font-bold text-warm-900 mb-2">What are your minimum order requirements?</h3>
          <p class="text-warm-600">We have no minimum for pickup orders. For delivery, we recommend at least 3 cubic yards to make delivery cost-effective.</p>
        </div>

        <div class="bg-warm-50 border border-secondary-200 rounded-lg p-6">
          <h3 class="font-bold text-warm-900 mb-2">Do you offer contractor pricing?</h3>
          <p class="text-warm-600">Yes! We offer volume discounts and account terms for landscapers and contractors. Contact us to learn about our contractor program.</p>
        </div>

        <div class="bg-warm-50 border border-secondary-200 rounded-lg p-6">
          <h3 class="font-bold text-warm-900 mb-2">Can I visit the farm to see the products?</h3>
          <p class="text-warm-600">Absolutely! We're open Monday through Saturday. Stop by to see our products in person before ordering.</p>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = btn.textContent;
    btn.textContent = 'Sending...';
    btn.disabled = true;

    try {
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.innerHTML = '<div class="text-center py-12"><h3 class="text-2xl font-bold text-warm-900 mb-4">Thank you!</h3><p class="text-warm-600">We\'ll get back to you within 24 hours. Or call us anytime at <a href="tel:+1-706-613-4415" class="text-accent-600 font-semibold">(706) 613-4415</a>.</p></div>';
      } else {
        throw new Error('Submit failed');
      }
    } catch (err) {
      btn.textContent = originalText;
      btn.disabled = false;
      alert('Something went wrong. Please call us at (706) 613-4415.');
    }
  });
</script>
