---
/**
 * Delivery Information
 * Route: /resources/delivery
 */

import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Delivery Info | Compost, Mulch & Topsoil Delivery | Soul Miner's Eden"
  description="Delivery information for bulk compost, mulch, and topsoil in the Athens, GA area. Free delivery on large orders. Same-week delivery available."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-500 to-primary-600 text-white py-16">
    <div class="container-custom">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">Delivery Information</h1>
        <p class="text-xl text-primary-100">
          We deliver bulk compost, mulch, and topsoil throughout the Athens area. Most orders go out same week.
        </p>
      </div>
    </div>
  </section>

  <div class="container-custom py-16">
    <!-- Delivery Area -->
    <section class="mb-16">
      <h2 class="text-3xl font-display font-bold text-warm-900 mb-6">Where We Deliver</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <p class="text-warm-700 mb-4">
            We deliver throughout the Athens-Clarke County area and surrounding communities, typically within 40 miles of our farm in Bogart, GA. That covers most of:
          </p>
          <ul class="grid grid-cols-2 gap-2 text-warm-700">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Athens-Clarke County
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Oconee County
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Madison County
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Jackson County
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Barrow County
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Walton County
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Oglethorpe County
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Morgan County
            </li>
          </ul>
          <p class="text-warm-500 text-sm mt-4">Not sure if you're in range? Just call — we'll figure it out.</p>
        </div>
        <div class="bg-warm-100 rounded-2xl p-8">
          <h3 class="text-xl font-bold text-warm-900 mb-4">Delivery Quick Facts</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="text-2xl font-bold text-primary-600">3+</span>
              <div>
                <p class="font-semibold text-warm-900">Cubic Yard Minimum</p>
                <p class="text-sm text-warm-600">For delivery to be cost-effective. No minimum for pickup.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-2xl font-bold text-primary-600">40</span>
              <div>
                <p class="font-semibold text-warm-900">Mile Radius</p>
                <p class="text-sm text-warm-600">From our farm in Bogart, GA. Farther? Call us.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-2xl font-bold text-accent-600">Same</span>
              <div>
                <p class="font-semibold text-warm-900">Week Delivery</p>
                <p class="text-sm text-warm-600">Most orders delivered within the same week.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What to Expect -->
    <section class="mb-16">
      <h2 class="text-3xl font-display font-bold text-warm-900 mb-6">What to Expect</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-warm-50 rounded-xl p-6">
          <div class="text-3xl font-bold text-primary-600 mb-2">1</div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">Place Your Order</h3>
          <p class="text-warm-600">Call us at <a href="tel:+1-706-613-4415" class="text-accent-600 font-semibold">(706) 613-4415</a> or use the <a href="/contact" class="text-accent-600 font-semibold">contact form</a>. Tell us what you need, how much, and where it's going.</p>
        </div>
        <div class="bg-warm-50 rounded-xl p-6">
          <div class="text-3xl font-bold text-primary-600 mb-2">2</div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">We Confirm Details</h3>
          <p class="text-warm-600">We'll confirm the delivery fee (based on distance and quantity), schedule a delivery window, and answer any product questions.</p>
        </div>
        <div class="bg-warm-50 rounded-xl p-6">
          <div class="text-3xl font-bold text-primary-600 mb-2">3</div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">We Deliver</h3>
          <p class="text-warm-600">Our driver will call when they're on the way. Please have someone on-site to direct placement. We dump from the truck — no wheelbarrowing.</p>
        </div>
      </div>
    </section>

    <!-- Pickup -->
    <section class="mb-16">
      <h2 class="text-3xl font-display font-bold text-warm-900 mb-6">Prefer Pickup?</h2>
      <div class="bg-warm-100 rounded-2xl p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div>
            <p class="text-warm-700 mb-4">
              Drive right in and we'll load your truck or trailer. No minimum order for pickup. Call ahead for large orders so we can have everything ready.
            </p>
            <div class="space-y-2 text-warm-700">
              <p><strong>Address:</strong> 189 Luke Road, Bogart, GA 30622</p>
              <p><strong>Hours:</strong> Monday–Saturday, 8am–6pm</p>
              <p><strong>Phone:</strong> <a href="tel:+1-706-613-4415" class="text-accent-600">(706) 613-4415</a></p>
            </div>
          </div>
          <div class="text-warm-600">
            <h3 class="text-lg font-bold text-warm-900 mb-3">Bring the right vehicle</h3>
            <ul class="space-y-2 text-sm">
              <li>1–2 cubic yards: Pickup truck works fine</li>
              <li>3–5 cubic yards: Full-size truck or small trailer</li>
              <li>5+ cubic yards: Large trailer recommended (or schedule delivery)</li>
            </ul>
            <p class="text-xs text-warm-500 mt-3">One cubic yard of compost weighs roughly 1,000–1,400 lbs. Please know your vehicle's payload rating.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="text-center">
      <div class="bg-gradient-to-br from-primary-600 to-primary-700 text-white rounded-2xl p-8 md:p-12 max-w-3xl mx-auto">
        <h2 class="text-3xl font-display font-bold mb-4">Ready to Order?</h2>
        <p class="text-primary-100 mb-8">Call us or fill out the contact form and we'll get back to you the same day.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="tel:+1-706-613-4415" class="bg-white text-primary-700 font-semibold py-3 px-8 rounded-full hover:bg-primary-50 transition-colors">
            Call (706) 613-4415
          </a>
          <a href="/contact" class="border-2 border-white text-white font-semibold py-3 px-8 rounded-full hover:bg-white/10 transition-colors">
            Contact Form
          </a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>
