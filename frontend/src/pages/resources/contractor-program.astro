---
/**
 * Contractor Program
 * Route: /resources/contractor-program
 */

import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Contractor & Landscaper Program | Bulk Pricing | Soul Miner's Eden"
  description="Volume pricing, account terms, and priority delivery for landscapers and contractors in the Athens, GA area. Compost, mulch, topsoil, and soil blends."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-warm-800 to-warm-900 text-white py-16">
    <div class="container-custom">
      <div class="max-w-3xl">
        <p class="text-warm-400 font-medium mb-3 uppercase tracking-wide text-sm">For Landscapers & Contractors</p>
        <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">Contractor Program</h1>
        <p class="text-xl text-warm-300">
          Volume pricing, account terms, and reliable supply for the professionals who build and maintain Athens-area landscapes.
        </p>
      </div>
    </div>
  </section>

  <div class="container-custom py-16">
    <!-- Why Contractors Choose Us -->
    <section class="mb-16">
      <h2 class="text-3xl font-display font-bold text-warm-900 mb-8 text-center">Why Contractors Choose Eden</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-warm-50 rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">Volume Pricing</h3>
          <p class="text-warm-600 text-sm">Tiered discounts on bulk orders. The more you buy, the better the price.</p>
        </div>
        <div class="bg-warm-50 rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">Account Terms</h3>
          <p class="text-warm-600 text-sm">Net-30 terms for qualified contractors. Order now, pay after the job.</p>
        </div>
        <div class="bg-warm-50 rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-accent-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">Priority Delivery</h3>
          <p class="text-warm-600 text-sm">Account holders get priority scheduling. We know you're on a timeline.</p>
        </div>
        <div class="bg-warm-50 rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-accent-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">Consistent Quality</h3>
          <p class="text-warm-600 text-sm">Same product every time. No surprises on the job site.</p>
        </div>
      </div>
    </section>

    <!-- Products Available -->
    <section class="mb-16">
      <h2 class="text-3xl font-display font-bold text-warm-900 mb-6">Products for Professionals</h2>
      <div class="bg-warm-100 rounded-2xl p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-xl font-bold text-warm-900 mb-4">Bulk Materials</h3>
            <ul class="space-y-2 text-warm-700">
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-primary-600 rounded-full shrink-0"></span>
                <a href="/products/compost" class="hover:text-primary-600">Regenerative Compost</a>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-primary-600 rounded-full shrink-0"></span>
                <a href="/products/topsoil" class="hover:text-primary-600">Screened Topsoil</a>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-primary-600 rounded-full shrink-0"></span>
                <a href="/products/double-ground-hardwood-mulch" class="hover:text-primary-600">Natural Hardwood Mulch</a>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-primary-600 rounded-full shrink-0"></span>
                <a href="/products/brown-mulch" class="hover:text-primary-600">Brown Mulch</a>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-primary-600 rounded-full shrink-0"></span>
                <a href="/products/black-mulch" class="hover:text-primary-600">Black Mulch</a>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-warm-900 mb-4">Specialty & Spec Products</h3>
            <ul class="space-y-2 text-warm-700">
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-accent-600 rounded-full shrink-0"></span>
                <a href="/products/sod-soil" class="hover:text-accent-600">Sod Soil</a>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-accent-600 rounded-full shrink-0"></span>
                <a href="/products/bioretention-soil" class="hover:text-accent-600">Bioretention Soil (spec-grade)</a>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-accent-600 rounded-full shrink-0"></span>
                <a href="/products/wood-chips" class="hover:text-accent-600">Wood Chips</a>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-accent-600 rounded-full shrink-0"></span>
                Custom blends available — call to discuss
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="mb-16">
      <h2 class="text-3xl font-display font-bold text-warm-900 mb-6">How to Get Started</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="border border-warm-200 rounded-xl p-6">
          <div class="text-3xl font-bold text-primary-600 mb-2">1</div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">Call Us</h3>
          <p class="text-warm-600">Call <a href="tel:+1-706-613-4415" class="text-accent-600 font-semibold">(706) 613-4415</a> or fill out the form below. Let us know what you do and what you typically need.</p>
        </div>
        <div class="border border-warm-200 rounded-xl p-6">
          <div class="text-3xl font-bold text-primary-600 mb-2">2</div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">We Set Up Your Account</h3>
          <p class="text-warm-600">We'll set your pricing tier, discuss terms, and add you to our contractor list for priority scheduling.</p>
        </div>
        <div class="border border-warm-200 rounded-xl p-6">
          <div class="text-3xl font-bold text-primary-600 mb-2">3</div>
          <h3 class="text-lg font-bold text-warm-900 mb-2">Order When You Need</h3>
          <p class="text-warm-600">Call or text your order. We'll schedule delivery around your job timeline. Simple as that.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="text-center">
      <div class="bg-gradient-to-br from-warm-800 to-warm-900 text-white rounded-2xl p-8 md:p-12 max-w-3xl mx-auto">
        <h2 class="text-3xl font-display font-bold mb-4">Set Up Your Contractor Account</h2>
        <p class="text-warm-300 mb-8">Call us and we'll get your pricing and terms set up in one conversation. Most contractors are ordering within the same week.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="tel:+1-706-613-4415" class="bg-primary-600 text-white font-semibold py-3 px-8 rounded-full hover:bg-primary-700 transition-colors">
            Call (706) 613-4415
          </a>
          <a href="/contact" class="border-2 border-warm-400 text-warm-200 font-semibold py-3 px-8 rounded-full hover:bg-white/10 transition-colors">
            Contact Form
          </a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>
