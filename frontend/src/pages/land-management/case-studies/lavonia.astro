---
/**
 * Lavonia Solar Grazing Case Study
 *
 * 150-acre solar installation in Northeast Georgia.
 * First active agrivoltaic contract for Soul Miner's Eden.
 * Route: /land-management/case-studies/lavonia
 */

import MainLayout from '../../../layouts/MainLayout.astro';
import CaseStudy from '../../../components/CaseStudy.astro';
import { buildCloudinaryUrl } from '../../../lib/cloudinary';

const ogImage = buildCloudinaryUrl('Animals/solar-grazing/IMG_3679_dkimqi', {
  width: 1200,
  height: 630,
  crop: 'fill',
  gravity: 'auto',
  quality: 'auto',
  format: 'jpg',
});

const caseStudyData = {
  title: "150-Acre Solar Site in Northeast Georgia",
  location: "Northeast Georgia (Lavonia area)",
  acreage: "150+",
  serviceType: "Agrivoltaic Vegetation Management",
  status: "Active — Ongoing",
  challenge: "A 150-acre utility-scale solar installation needed reliable, local vegetation management. The previous mowing provider was traveling long distances, driving up costs and reducing response time. The site's vegetation — a mix of warm-season grasses and emerging invasives — required consistent management to prevent panel shading and fire risk buildup.",
  solution: "We evaluated the site on foot, assessed vegetation types and panel layout, and designed a rotational grazing plan tailored to the installation's geometry. Our flock was deployed with portable fencing and water systems. Bo Carter leads the grazing operation, managing regular rotation through sections, giving each area time to recover while keeping the entire site under active control. This isn't just vegetation management — it's an agrivoltaic system where the land stays in agricultural production while generating clean energy.",
  results: [
    "Site under active, ongoing management with regular animal oversight",
    "Vegetation controlled across all 150+ acres without mowing equipment",
    "Zero panel incidents — no thrown rocks, no cracked glass, no severed wiring",
    "Soil health improving through natural fertilization and rotational grazing",
    "Local operator eliminates long-distance travel costs for the site owner",
    "Land kept in agricultural production — a true dual-use agrivoltaic system"
  ],
  images: [
    {
      publicId: 'Animals/solar-grazing/IMG_3679_dkimqi',
      alt: 'Sheep grazing under solar panels at the Lavonia site',
      caption: 'Active grazing between panel rows'
    },
    {
      publicId: 'Animals/solar-grazing/IMG_3685_dqh8sh',
      alt: 'Solar grazing site overview in Northeast Georgia',
      caption: 'Vegetation management across the 150-acre installation'
    },
    {
      publicId: 'Animals/solar-grazing/IMG_3683_kzbayx',
      alt: 'Flock managing vegetation at solar farm',
      caption: 'Rotational grazing keeps vegetation at optimal height'
    }
  ]
};
---

<MainLayout
  title="Solar Grazing Case Study: 150-Acre Site in Northeast Georgia | Soul Miner's Eden"
  description="Case study: How Soul Miner's Eden manages vegetation on a 150-acre solar installation in Northeast Georgia using sheep-based agrivoltaic grazing. Zero panel damage, healthier soil."
  ogImage={ogImage}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-warm-800 to-warm-900 text-white py-12 md:py-16">
    <div class="container-custom">
      <nav class="text-warm-400 text-sm mb-6">
        <a href="/land-management" class="hover:text-white">Land Management</a>
        <span class="mx-2">/</span>
        <a href="/land-management/solar-grazing" class="hover:text-white">Solar Grazing</a>
        <span class="mx-2">/</span>
        <a href="/land-management/case-studies" class="hover:text-white">Case Studies</a>
        <span class="mx-2">/</span>
        <span class="text-warm-200">Northeast Georgia</span>
      </nav>

      <div class="inline-flex items-center gap-2 bg-accent-600/80 backdrop-blur-sm px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        Active Site
      </div>

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold mb-4">
        {caseStudyData.title}
      </h1>
      <p class="text-xl text-warm-300 max-w-2xl">
        How a regenerative farm brought agrivoltaic grazing to a utility-scale solar installation — and made the land better in the process.
      </p>
    </div>
  </section>

  <!-- Case Study Content -->
  <div class="container-custom py-12 md:py-16">
    <CaseStudy
      title={caseStudyData.title}
      location={caseStudyData.location}
      acreage={caseStudyData.acreage}
      serviceType={caseStudyData.serviceType}
      status={caseStudyData.status}
      challenge={caseStudyData.challenge}
      solution={caseStudyData.solution}
      results={caseStudyData.results}
      images={caseStudyData.images}
    />

    <!-- Agrivoltaics Context -->
    <div class="max-w-3xl mx-auto mt-16">
      <div class="bg-accent-50 border-l-4 border-accent-500 p-6 rounded-r-lg">
        <h3 class="text-lg font-bold text-warm-900 mb-3">What Makes This Agrivoltaic?</h3>
        <p class="text-warm-700">
          This isn't just vegetation management. By keeping sheep on the land, we maintain active agricultural production on the same acres that generate clean energy. The U.S. Department of Energy calls this "dual-use solar" or agrivoltaics — and it's the future of how solar installations and rural communities can work together. The land stays productive. The community sees a working farm, not an industrial site. And the panels perform better because vegetation cooling keeps temperatures down.
        </p>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <div class="bg-gradient-to-br from-accent-600 to-accent-700 text-white rounded-2xl p-8 md:p-12 max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">
          Is Your Solar Site a Fit?
        </h2>
        <p class="text-accent-100 mb-8">
          We're taking on new sites across Georgia for 2026. Free assessment, honest evaluation.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/land-management/request" class="btn bg-white text-accent-700 hover:bg-accent-50 text-lg px-8 py-4 font-semibold">
            Get Your Free Site Assessment
          </a>
          <a href="/land-management/solar-grazing" class="btn border-2 border-white text-white hover:bg-white/10 text-lg px-8 py-4">
            Learn About Solar Grazing
          </a>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
