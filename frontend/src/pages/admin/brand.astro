---
/**
 * Brand Cheat Sheet
 *
 * Quick reference for anyone writing, posting, or creating for SME.
 * Keep it simple — a 15-year-old should be able to follow this.
 */

import AdminLayout from '../../layouts/AdminLayout.astro';

const brandColors = [
  { name: 'Clay', hex: '#A8643F', use: 'Warm accent, links', light: false },
  { name: 'Sage', hex: '#4D6B42', use: 'Buttons & CTAs', light: false },
  { name: 'Steel', hex: '#6E6E68', use: 'Secondary text, borders', light: false },
  { name: 'Charcoal', hex: '#2D2926', use: 'Text & headings', light: false },
  { name: 'Cream', hex: '#FAF8F5', use: 'Backgrounds', light: true },
];

const weSound = [
  'Calm and confident',
  'A little poetic, but real',
  'Faith shows through — never pushy',
  'Premium, not salesy',
  'Always inviting — "come see for yourself"',
];

const neverSay = [
  '"Cheap," "discount," "affordable," or "expensive"',
  '"Certified" — say "Regenerative"',
  '"Landscape supply store" or "mulch yard" — say "regenerative farm with compost and soil"',
  'Corporate words like "solutions" or "leverage"',
  'Pushy religion',
  'If it sounds like a Hallmark card, cut it in half',
];

const examples = [
  { yes: 'We sit on 5,000 tons of compost with zero competitors within 60 miles.', no: 'We\'re trying to build something special!' },
  { yes: 'Built on faith-driven stewardship and honest work.', no: 'Jesus wants you to buy organic compost!' },
  { yes: 'Drive in, walk through the arbor, pay what you owe. Simple.', no: 'Please follow all posted signage and payment procedures.' },
  { yes: 'Come enjoy our little slice of Eden with a farm tour.', no: 'Transform your lifestyle with our holistic Eden experience.' },
];

const phrases = [
  'A working demonstration of Southland biology',
  'Honor-system farm stand on a regenerative farm outside Athens',
  'Camera-ready proof that biology works',
  'Your own piece of Eden',
  'The way creation was designed to work',
  'Soil, story, and supper in Bogart',
  'Built on faith-driven stewardship',
  'Come see for yourself',
  'Born from Southland\'s soil biology, grown into a working farm',
];

const honorStand = [
  { item: 'Pasture-raised eggs', price: '$8–12/dz' },
  { item: 'Raw milk (Grade A)', price: '$10–12/gal' },
  { item: 'Whole chicken', price: '$25–35 ea' },
  { item: 'Bone broth', price: '$15–20/qt' },
  { item: 'Lamb cuts', price: '$12–18/lb' },
  { item: 'Seasonal fruit', price: '$5–12/lb' },
  { item: 'Honey', price: '$12–18/lb' },
  { item: 'Bagged compost', price: '$8–12/bag' },
];
---

<AdminLayout title="Brand Cheat Sheet" description="How we look, sound, and show up">

  <!-- Who We Are -->
  <div class="admin-card" style="margin-bottom: 2rem;">
    <div class="admin-card-body" style="padding: 1.5rem;">
      <p style="font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-size: 1.25rem; color: #2D2926; line-height: 1.6; margin: 0 0 0.5rem;">
        "A regenerative farm in Bogart, Georgia."
      </p>
      <p style="font-size: 0.75rem; color: #6E6E68; margin: 0 0 1rem; font-style: italic;">
        Use this exact tagline everywhere short-form (IG, FB, directory listings). For longer copy and About pages: "A 65-acre regenerative demonstration farm in Bogart, Georgia."
      </p>
      <p style="font-size: 0.938rem; color: #6E6E68; margin: 0 0 0.75rem;">
        We sell beauty, trust, and story first — products second. We're not a landscape supply yard with a nice story. We're a family farm, and everything flows from that.
      </p>
      <p style="font-size: 0.813rem; color: #6E6E68; margin: 0;">
        We do sell mulch, compost, and soil — but always framed as farm-grown biology, not generic landscape supply.
      </p>
    </div>
  </div>

  <!-- Our Colors + Logo side by side -->
  <div class="admin-grid-2" style="margin-bottom: 2rem;">
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">Our Colors</h2>
      </div>
      <div class="admin-card-body">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
          {brandColors.map(c => (
            <div>
              <div style={`background: ${c.hex}; height: 64px; border-radius: 8px; display: flex; align-items: flex-end; padding: 0.5rem; ${c.light ? 'border: 1px solid #B0B0AA;' : ''}`}>
                <span style={`font-size: 0.75rem; font-weight: 600; color: ${c.light ? '#6E6E68' : 'rgba(255,255,255,0.9)'};`}>{c.hex}</span>
              </div>
              <div style="margin-top: 0.375rem;">
                <div style="font-weight: 600; font-size: 0.875rem;">{c.name}</div>
                <div style="font-size: 0.75rem; color: #6E6E68;">{c.use}</div>
              </div>
            </div>
          ))}
        </div>
        <div style="background: #F0EDE8; padding: 0.75rem; border-radius: 6px; margin-top: 1rem; font-size: 0.75rem; color: #6E6E68;">
          <strong style="color: #2D2926;">Rules:</strong> Never use clay text on cream below 14px. Use charcoal for all body copy. Buttons: sage background + cream text, clay for hover.
        </div>
      </div>
    </div>

    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">Logo</h2>
      </div>
      <div class="admin-card-body">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div>
            <div style="background: #FAF8F5; padding: 1.5rem; border-radius: 8px; display: flex; justify-content: center; align-items: center; border: 1px solid #B0B0AA; height: 120px;">
              <img
                src="/brand/logo-primary.svg"
                alt="Soul Miner's Eden Logo — Primary"
                style="max-height: 80px; width: auto;"
              />
            </div>
            <div style="font-size: 0.75rem; color: #6E6E68; margin-top: 0.375rem; text-align: center;">Primary (sage + clay)</div>
          </div>
          <div>
            <div style="background: #2D2926; padding: 1.5rem; border-radius: 8px; display: flex; justify-content: center; align-items: center; height: 120px;">
              <img
                src="/brand/logo-reversed.svg"
                alt="Soul Miner's Eden Logo — Reversed"
                style="max-height: 80px; width: auto;"
              />
            </div>
            <div style="font-size: 0.75rem; color: #6E6E68; margin-top: 0.375rem; text-align: center;">Reversed (white)</div>
          </div>
        </div>
        <div style="background: #F0EDE8; padding: 0.75rem; border-radius: 6px; margin-top: 1rem; text-align: center;">
          <div style="font-family: 'EB Garamond', Georgia, serif; font-weight: 400; letter-spacing: 0.2em; font-size: 1.25rem; color: #A8643F;">SOUL MINER'S EDEN</div>
          <div style="font-family: 'EB Garamond', Georgia, serif; font-size: 0.75rem; color: #6E6E68; letter-spacing: 0.2em;">Bogart, Georgia</div>
        </div>
        <div style="font-size: 0.75rem; color: #6E6E68; margin-top: 0.75rem; line-height: 1.6;">
          <strong style="color: #2D2926;">Clear space:</strong> Keep space around logo equal to the height of the "S" in SOUL.<br/>
          <strong style="color: #2D2926;">Files:</strong> Use provided vector files only (SVG/AI/PDF). Never recreate the logo in Canva or retype the wordmark.
        </div>
      </div>
    </div>
  </div>

  <!-- Secondary Mark — Wheelbarrow -->
  <div class="admin-card" style="margin-bottom: 2rem;">
    <div class="admin-card-header">
      <h2 class="admin-card-title">Secondary Mark — Wheelbarrow</h2>
    </div>
    <div class="admin-card-body">
      <p style="font-size: 0.813rem; color: #6E6E68; margin-bottom: 1rem;">
        Use the wheelbarrow mark where the full logo is too large or complex. Represents the real wheelbarrow on property — compost, soil, growth.
      </p>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.25rem;">
        <div>
          <div style="background: #FAF8F5; padding: 1.25rem; border-radius: 8px; display: flex; justify-content: center; align-items: center; border: 1px solid #B0B0AA; height: 120px;">
            <img
              src="/brand/mark-wheelbarrow.svg"
              alt="Wheelbarrow mark — two-tone"
              style="max-height: 80px; width: auto;"
            />
          </div>
          <div style="font-size: 0.75rem; color: #6E6E68; margin-top: 0.375rem; text-align: center;">Two-tone (charcoal + sage)</div>
        </div>
        <div>
          <div style="background: #2D2926; padding: 1.25rem; border-radius: 8px; display: flex; justify-content: center; align-items: center; height: 120px;">
            <img
              src="/brand/mark-wheelbarrow-reversed.svg"
              alt="Wheelbarrow mark — reversed"
              style="max-height: 80px; width: auto;"
            />
          </div>
          <div style="font-size: 0.75rem; color: #6E6E68; margin-top: 0.375rem; text-align: center;">Reversed (white)</div>
        </div>
        <div>
          <div style="background: #FAF8F5; padding: 1.25rem; border-radius: 8px; display: flex; justify-content: center; align-items: center; border: 1px solid #B0B0AA; height: 120px;">
            <img
              src="/brand/mark-wheelbarrow-mono.svg"
              alt="Wheelbarrow mark — mono"
              style="max-height: 80px; width: auto;"
            />
          </div>
          <div style="font-size: 0.75rem; color: #6E6E68; margin-top: 0.375rem; text-align: center;">Mono (embroidery, stamps)</div>
        </div>
      </div>
      <div style="background: #F0EDE8; padding: 1rem; border-radius: 6px;">
        <h3 style="font-size: 0.813rem; font-weight: 600; margin-bottom: 0.5rem; color: #2D2926;">Usage Guidelines</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; font-size: 0.813rem; color: #6E6E68;">
          <div>
            <div style="font-weight: 600; color: #4D6B42; margin-bottom: 0.25rem;">Use for</div>
            <ul style="list-style: none; padding: 0; margin: 0;">
              <li style="padding: 0.125rem 0;">Social avatar & favicon (512x512, 32x32)</li>
              <li style="padding: 0.125rem 0;">Hat & merch embroidery (mono)</li>
              <li style="padding: 0.125rem 0;">Packaging accent stamp</li>
              <li style="padding: 0.125rem 0;">Watermark on photos</li>
            </ul>
          </div>
          <div>
            <div style="font-weight: 600; color: #991b1b; margin-bottom: 0.25rem;">Never</div>
            <ul style="list-style: none; padding: 0; margin: 0;">
              <li style="padding: 0.125rem 0;">Replace the primary logo with it</li>
              <li style="padding: 0.125rem 0;">Use below 0.75 inch wide</li>
              <li style="padding: 0.125rem 0;">Recolor outside the palette</li>
              <li style="padding: 0.125rem 0;">Add a drop shadow or outline</li>
              <li style="padding: 0.125rem 0;">Rotate, crop, or enclose in shapes</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- How We Sound -->
  <div class="admin-card" style="margin-bottom: 2rem;">
    <div class="admin-card-header">
      <h2 class="admin-card-title">How We Sound</h2>
    </div>
    <div class="admin-card-body">
      <div class="admin-grid-2">
        <div>
          <h3 style="font-size: 0.875rem; font-weight: 600; margin-bottom: 0.75rem; color: #4D6B42;">We sound like...</h3>
          <ul style="list-style: none;">
            {weSound.map(item => (
              <li style="padding: 0.375rem 0; font-size: 0.875rem; display: flex; align-items: flex-start; gap: 0.5rem;">
                <span style="color: #4D6B42;">&#10003;</span> {item}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 style="font-size: 0.875rem; font-weight: 600; margin-bottom: 0.75rem; color: #991b1b;">Never say...</h3>
          <ul style="list-style: none;">
            {neverSay.map(item => (
              <li style="padding: 0.375rem 0; font-size: 0.875rem; display: flex; align-items: flex-start; gap: 0.5rem;">
                <span style="color: #ef4444;">&#10007;</span> {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #B0B0AA;">
        <h3 style="font-size: 0.875rem; font-weight: 600; margin-bottom: 1rem; color: #6E6E68;">Examples</h3>
        {examples.map(ex => (
          <div style="margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid #F0EDE8;">
            <div style="display: flex; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.375rem;">
              <span style="color: #4D6B42; font-weight: 700;">&#10003;</span>
              <span style="font-size: 0.875rem; color: #4D6B42;">"{ex.yes}"</span>
            </div>
            <div style="display: flex; align-items: flex-start; gap: 0.5rem;">
              <span style="color: #ef4444; font-weight: 700;">&#10007;</span>
              <span style="font-size: 0.875rem; color: #991b1b; text-decoration: line-through;">"{ex.no}"</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Phrases You Can Use -->
  <div class="admin-card" style="margin-bottom: 2rem;">
    <div class="admin-card-header">
      <h2 class="admin-card-title">Phrases You Can Use</h2>
    </div>
    <div class="admin-card-body">
      <p style="font-size: 0.813rem; color: #6E6E68; margin-bottom: 1rem;">Copy these for posts, captions, signage — anywhere.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.625rem;">
        {phrases.map(phrase => (
          <div style="background: #FAF8F5; border-left: 3px solid #A8643F; padding: 0.625rem 1rem; border-radius: 0 6px 6px 0; font-size: 0.875rem; color: #2D2926;">
            {phrase}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Honor Stand Prices -->
  <div class="admin-card" style="margin-bottom: 2rem;">
    <div class="admin-card-header">
      <h2 class="admin-card-title">Honor Stand Prices</h2>
    </div>
    <div class="admin-card-body">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0;">
        {honorStand.map(p => (
          <div style="display: flex; justify-content: space-between; padding: 0.5rem 0.75rem; border-bottom: 1px solid #F0EDE8; font-size: 0.875rem;">
            <span>{p.item}</span>
            <span style="font-weight: 600; color: #6E6E68;">{p.price}</span>
          </div>
        ))}
      </div>
      <div style="background: #F0EDE8; padding: 0.75rem; border-radius: 6px; margin-top: 1rem; font-size: 0.75rem; color: #6E6E68; line-height: 1.6;">
        Prices flex by season and availability. Honor-stand signage is always the source of truth.<br/>
        <strong style="color: #2D2926;">How to talk about prices:</strong> Say "priced to honor the work and the land." Never say "expensive" or "cheap."
      </div>
    </div>
  </div>

  <!-- Honor Stand Operations -->
  <div class="admin-card" style="margin-bottom: 2rem;">
    <div class="admin-card-header">
      <h2 class="admin-card-title">Honor Stand Operations</h2>
    </div>
    <div class="admin-card-body">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; font-size: 0.875rem;">
        <div>
          <div style="font-weight: 600; color: #2D2926; margin-bottom: 0.5rem;">Hours</div>
          <p style="color: #6E6E68; margin: 0;">Generally sunrise to dark. If the gate is open, the stand is open.</p>
        </div>
        <div>
          <div style="font-weight: 600; color: #2D2926; margin-bottom: 0.5rem;">How It Works</div>
          <p style="color: #6E6E68; margin: 0;">Grab what you need, total it up, pay by cash, check, or QR code, and sign your name.</p>
        </div>
      </div>
      <div style="font-size: 0.75rem; color: #6E6E68; margin-top: 1rem;">
        <strong style="color: #2D2926;">Address:</strong> 189 Luke Road, Bogart, GA 30622 &nbsp;&middot;&nbsp; <strong style="color: #2D2926;">Phone:</strong> (706) 613-4415
      </div>
    </div>
  </div>

  <!-- Social & Bio -->
  <div class="admin-card" style="margin-bottom: 2rem;">
    <div class="admin-card-header">
      <h2 class="admin-card-title">Social & Bio</h2>
    </div>
    <div class="admin-card-body">
      <div style="background: #F0EDE8; padding: 1rem; border-radius: 6px; margin-bottom: 1.25rem;">
        <div style="font-weight: 600; font-size: 0.813rem; color: #2D2926; margin-bottom: 0.5rem;">Locked Bio (use everywhere)</div>
        <div style="font-size: 0.875rem; color: #2D2926; line-height: 1.6;">
          A regenerative farm in Bogart, Georgia.<br/>
          A Southland Organics Company.
        </div>
        <div style="font-size: 0.75rem; color: #6E6E68; margin-top: 0.5rem;">
          Include "A Southland Organics Company" on any platform bio where space allows (Instagram, Facebook, Google Business Profile).
        </div>
      </div>

      <div style="font-weight: 600; font-size: 0.813rem; color: #2D2926; margin-bottom: 0.5rem;">Default Hashtags</div>
      <div style="font-size: 0.875rem; color: #6E6E68; margin-bottom: 1.25rem;">
        #soulminerseden #regenerative #bogart #honorstand
      </div>

      <div style="font-weight: 600; font-size: 0.813rem; color: #2D2926; margin-bottom: 0.75rem;">Post Templates</div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          <div style="font-size: 0.75rem; font-weight: 600; color: #4D6B42; margin-bottom: 0.375rem;">Honor Stand</div>
          <div style="background: #FAF8F5; padding: 1rem; border-radius: 8px; font-size: 0.813rem; color: #2D2926; line-height: 1.8;">
            <div>[Photo of stand display]</div>
            <div style="margin-top: 0.375rem;"><strong>Honor Stand Today:</strong> fresh eggs, raw milk, bone broth, and muscadines.</div>
            <div>Open until dark. 189 Luke Road, Bogart.</div>
            <div style="color: #6E6E68; margin-top: 0.375rem;">#soulminerseden #honorstand #bogart</div>
          </div>
        </div>
        <div>
          <div style="font-size: 0.75rem; font-weight: 600; color: #4D6B42; margin-bottom: 0.375rem;">Farm + Compost</div>
          <div style="background: #FAF8F5; padding: 1rem; border-radius: 8px; font-size: 0.813rem; color: #2D2926; line-height: 1.8;">
            <div>[Photo of compost or soil]</div>
            <div style="margin-top: 0.375rem;"><strong>Honor Stand Today:</strong> bagged compost, living soil, and pasture-raised eggs.</div>
            <div>Come see the farm at 189 Luke Road, Bogart.</div>
            <div style="color: #6E6E68; margin-top: 0.375rem;">#soulminerseden #regenerative #compost</div>
          </div>
        </div>
      </div>
    </div>
  </div>

</AdminLayout>
