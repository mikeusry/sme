---
/**
 * Admin Dashboard
 *
 * Overview of site health, content status, and quick actions
 */

import AdminLayout from '../../layouts/AdminLayout.astro';

const stats = {
  pages: 25,
  products: 13,
  blogPosts: 8,
  teamMembers: 10,
};

const recentActivity = [
  { action: 'Launch prep', target: 'Full site audit + fixes', time: 'Mar 17' },
  { action: 'Team page', target: '/team — 10 members', time: 'Mar 17' },
  { action: 'SendGrid + Klaviyo', target: 'Email notifications live', time: 'Mar 17' },
  { action: 'Redirect map', target: '28 Webflow → Astro redirects', time: 'Mar 17' },
  { action: 'Solar grazing', target: 'Dust/soiling data, case study', time: 'Mar 16' },
  { action: 'Medusa audit', target: 'SKUs, prices, thumbnails synced', time: 'Mar 16' },
];

const contentStatus = [
  { page: 'Home', status: 'live', hasRealContent: true },
  { page: 'About', status: 'live', hasRealContent: true },
  { page: 'Contact', status: 'live', hasRealContent: true },
  { page: 'Products (13)', status: 'live', hasRealContent: true },
  { page: 'Land Management', status: 'live', hasRealContent: true },
  { page: 'Solar Grazing', status: 'live', hasRealContent: true },
  { page: 'Case Studies', status: 'live', hasRealContent: true },
  { page: 'Team', status: 'live', hasRealContent: true },
  { page: 'Blog (8 posts)', status: 'live', hasRealContent: true },
  { page: 'Recipes (26)', status: 'live', hasRealContent: true },
];
---

<AdminLayout title="Dashboard" description="Overview of Soul Miner's Eden website status">
  <!-- Stats Grid -->
  <div class="admin-grid-4" style="margin-bottom: 2rem;">
    <div class="admin-card">
      <div class="admin-stat">
        <div class="stat-value">{stats.pages}</div>
        <div class="stat-label">Pages</div>
      </div>
    </div>
    <div class="admin-card">
      <div class="admin-stat">
        <div class="stat-value">{stats.products}</div>
        <div class="stat-label">Products</div>
      </div>
    </div>
    <div class="admin-card">
      <div class="admin-stat">
        <div class="stat-value">{stats.blogPosts}</div>
        <div class="stat-label">Blog Posts</div>
      </div>
    </div>
    <div class="admin-card">
      <div class="admin-stat">
        <div class="stat-value">{stats.teamMembers}</div>
        <div class="stat-label">Team Members</div>
      </div>
    </div>
  </div>

  <div class="admin-grid-2">
    <!-- Content Status -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">Content Status</h2>
      </div>
      <div class="admin-card-body">
        <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
          <thead>
            <tr style="border-bottom: 1px solid #e7e5e4;">
              <th style="text-align: left; padding: 0.5rem; color: #78716c;">Page</th>
              <th style="text-align: left; padding: 0.5rem; color: #78716c;">Status</th>
              <th style="text-align: left; padding: 0.5rem; color: #78716c;">Issues</th>
            </tr>
          </thead>
          <tbody>
            {contentStatus.map(item => (
              <tr style="border-bottom: 1px solid #e7e5e4;">
                <td style="padding: 0.5rem;">{item.page}</td>
                <td style="padding: 0.5rem;">
                  <span class={`admin-badge admin-badge-${item.status === 'live' ? 'success' : 'warning'}`}>
                    {item.status}
                  </span>
                </td>
                <td style="padding: 0.5rem; color: #78716c;">
                  {item.hasRealContent ? (
                    <span style="color: #4D6B42;">Ready</span>
                  ) : (
                    <span style="color: #ef4444;">Needs content</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">Recent Activity</h2>
      </div>
      <div class="admin-card-body">
        <ul style="list-style: none; font-size: 0.875rem;">
          {recentActivity.map(item => (
            <li style="padding: 0.75rem 0; border-bottom: 1px solid #e7e5e4; display: flex; justify-content: space-between;">
              <span>
                <strong>{item.action}</strong>
                <span style="color: #78716c;"> - {item.target}</span>
              </span>
              <span style="color: #78716c; font-size: 0.75rem;">{item.time}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="admin-card" style="margin-top: 2rem;">
    <div class="admin-card-header">
      <h2 class="admin-card-title">Quick Actions</h2>
    </div>
    <div class="admin-card-body">
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="/admin/brand" style="display: inline-flex; align-items: center; padding: 0.5rem 1rem; background: #A8643F; color: white; border-radius: 6px; text-decoration: none; font-size: 0.875rem; font-weight: 500;">
          View Brand Guide
        </a>
        <a href="/" target="_blank" style="display: inline-flex; align-items: center; padding: 0.5rem 1rem; background: #f5f5f4; color: #44403c; border: 1px solid #e7e5e4; border-radius: 6px; text-decoration: none; font-size: 0.875rem; font-weight: 500;">
          Preview Site
        </a>
      </div>
    </div>
  </div>
</AdminLayout>
