---
import MainLayout from '../layouts/MainLayout.astro';
import ProductCard from '../components/products/ProductCard.astro';
import MaterialCalculator from '../components/products/MaterialCalculator.astro';
import ProductImage from '../components/ProductImage.astro';
import CloudinaryImage from '../components/CloudinaryImage.astro';
import ExperienceFarm from '../components/ExperienceFarm.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import { getFeaturedProducts, getProductBySlug } from '../lib/products';

// Get featured products for showcase
const featuredProducts = getFeaturedProducts();

// Get specific hero products
const humusCompost = getProductBySlug('humus-compost');
const brownMulch = getProductBySlug('brown-mulch');
const topsoil = getProductBySlug('topsoil');

// MUX video playback ID for hero background
const muxPlaybackId = 'at00mmiQBibWz00AYKl2KvgHltoP7hzkRX02NtjzpMLX7w';
const muxPosterUrl = `https://image.mux.com/${muxPlaybackId}/thumbnail.jpg?time=0`;
const muxStreamUrl = `https://stream.mux.com/${muxPlaybackId}.m3u8`;
---

<MainLayout
	title="Soul Miner's Eden | Organic Compost & Land Management | Bogart, GA"
	description="Regenerative compost, mulch, and grazing services from our 65-acre farm in Bogart, Georgia. Family-owned, biology-driven."
>
	<!-- Hero Section -->
	<section class="hero-section relative py-20 md:py-28 overflow-hidden">
		<!-- Background Video -->
		<div class="hero-video-wrapper">
			<video
				id="hero-video"
				class="hero-video"
				autoplay
				muted
				loop
				playsinline
				poster={muxPosterUrl}
				data-stream-url={muxStreamUrl}
			>
			</video>
		</div>
		<!-- Dark overlay for text readability -->
		<div class="hero-overlay"></div>

		<div class="container-custom relative z-10">
			<div class="max-w-4xl mx-auto text-center">
				<!-- Badge — clay pill -->
				<div class="inline-flex items-center gap-2 bg-primary-500/80 backdrop-blur-sm px-5 py-2 rounded-full mb-6">
					<span class="text-sm font-semibold text-white">A regenerative farm in Bogart, Georgia</span>
				</div>

				<!-- Main headline -->
				<h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold mb-6 text-white leading-tight">
					Cultivate What the Land Was Meant to Be
				</h1>

				<!-- Subheadline — one tight sentence -->
				<p class="text-xl md:text-2xl mb-10 text-white/90 max-w-3xl mx-auto leading-relaxed">
					From our 65&#8209;acre regenerative farm in Bogart, we deliver compost, mulch, and grazing that prove biology works.
				</p>

				<!-- Dual CTAs — primary sage (larger) + outline clay -->
				<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
					<a href="/products" class="bg-accent-600 hover:bg-accent-700 text-white text-lg md:text-xl px-12 py-5 rounded-lg font-semibold transition-colors shadow-lg">
						Shop Compost & Mulch
					</a>
					<a href="/land-management" class="border-2 border-primary-300 text-primary-200 hover:bg-white/10 hover:text-white hover:border-white/70 text-base px-8 py-3 rounded-lg font-semibold transition-colors sm:inline-block hidden">
						Explore Grazing Services
					</a>
					<a href="/land-management" class="text-primary-200 hover:text-white font-semibold transition-colors underline underline-offset-4 sm:hidden">
						Explore Grazing Services →
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Value Props -->
	<section class="section bg-white">
		<div class="container-custom">
			<!-- Section header -->
			<div class="text-center mb-14">
				<h2 class="text-3xl md:text-4xl font-display font-bold text-warm-900 mb-4">
					Why Landscapers & Homeowners Choose Us
				</h2>
				<p class="text-lg text-warm-600 max-w-2xl mx-auto">
					From our farm to your property — thoughtfully produced, delivered with care.
				</p>
			</div>

			<!-- Value prop grid - 4 across -->
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
				<!-- Real Compost -->
				<div class="feature-box py-8 px-6 rounded-xl text-center">
					<div class="text-primary-500 mb-5">
						<!-- Compost heap icon -->
						<svg class="w-10 h-10 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 19c0-1.5 1.5-3 6-3s6 1.5 6 3" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M5 16c0-1.5 2-3 7-3s7 1.5 7 3" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M4 13c0-1.5 2.5-3 8-3s8 1.5 8 3" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 5v2m0 0c-.5.5-1.5 1-1.5 2M12 7c.5.5 1.5 1 1.5 2" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-warm-900">Real Compost, Zero Shortcuts</h3>
					<p class="text-warm-600">No biosolids. No fillers. Biologically active compost made on our farm with Southland biology.</p>
				</div>

				<!-- Grown Right -->
				<div class="feature-box py-8 px-6 rounded-xl text-center">
					<div class="text-primary-500 mb-5">
						<!-- Sprout icon -->
						<svg class="w-10 h-10 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 21V12m0 0c-2-4-6-5-9-4 3-1 7 0 9 4zm0 0c2-4 6-5 9-4-3-1-7 0-9 4z" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 12V8m-2 1c0-2 1-4 2-5 1 1 2 3 2 5" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-warm-900">Grown the Right Way</h3>
					<p class="text-warm-600">We work with the land, not against it — natural processes that build soil health and long-term performance.</p>
				</div>

				<!-- Local Delivery -->
				<div class="feature-box py-8 px-6 rounded-xl text-center">
					<div class="text-primary-500 mb-5">
						<!-- Truck icon -->
						<svg class="w-10 h-10 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-warm-900">Local Delivery</h3>
					<p class="text-warm-600">Trailer loads and supersacks throughout the Athens area. Volume pricing for landscapers and contractors.</p>
					<span class="text-sm text-primary-600 font-semibold mt-3 block">$40 base + $1.25/mile after 20 mi</span>
				</div>

				<!-- Family-Owned -->
				<div class="feature-box py-8 px-6 rounded-xl text-center">
					<div class="text-primary-500 mb-5">
						<!-- Farmhouse icon -->
						<svg class="w-10 h-10 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-warm-900">Family Farm, Faith-Driven Work</h3>
					<p class="text-warm-600">Built on stewardship and honest work. Serving the Athens community as a Southland Organics company.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Featured Products -->
	<section class="section bg-white">
		<div class="container-custom">
			<!-- Section header -->
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-display font-bold text-warm-900 mb-4">
					Premium Landscape Supply
				</h2>
				<p class="text-lg text-warm-600 max-w-2xl mx-auto">
					Compost, mulch, and soil — made on our farm, delivered to your project.
				</p>
			</div>

			<!-- Product showcase grid -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
				{humusCompost && (
					<ProductCard product={humusCompost} variant="featured" />
				)}

				{brownMulch && (
					<ProductCard product={brownMulch} variant="default" />
				)}

				{topsoil && (
					<ProductCard product={topsoil} variant="default" />
				)}
			</div>

			<!-- View all CTA -->
			<div class="text-center">
				<a href="/products" class="btn-primary text-lg px-10 py-4">
					View All Products
				</a>
				<p class="mt-4 text-sm text-warm-600">
					<a href="/contact" class="font-semibold text-primary-600 hover:text-primary-700">
						Contractor pricing available
					</a> — volume discounts and account terms
				</p>
			</div>
		</div>
	</section>

	<!-- Land Management Services -->
	<section class="section bg-gradient-to-br from-primary-500 to-primary-600 text-white mt-4 md:mt-6">
		<div class="container-custom">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<!-- Content column -->
				<div>
					<span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-1.5 rounded-full text-sm font-medium mb-4">Now managing 150+ acres</span>

					<h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-tight">
						Eden Grazing Services
					</h2>

					<p class="text-xl mb-6 text-primary-50 leading-relaxed">
						From HOA common areas to 150-acre solar installations — our animals are on the ground, doing the work. They eat the stuff you don't want, save you money, and leave the land better than they found it.
					</p>

					<p class="text-lg mb-6 font-semibold">
						150+ acres under active management. Up to 50% savings vs. mowing.
					</p>

					<div class="flex flex-wrap gap-3 mb-8">
						<span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm">Solar farms</span>
						<span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm">Retention ponds</span>
						<span class="bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm">HOAs & large properties</span>
					</div>

					<a href="/land-management" class="inline-block bg-accent-600 hover:bg-accent-700 text-white text-lg px-8 py-4 rounded-lg font-semibold transition-colors shadow-lg">
						Talk About Grazing Your Land
					</a>
				</div>

				<!-- Image column -->
				<div class="rounded-2xl overflow-hidden shadow-xl hidden lg:block">
					<CloudinaryImage
						publicId="Animals/solar-grazing/IMG_3679_dkimqi"
						alt="Sheep grazing under solar panels at Soul Miner's Eden"
						width={800}
						height={600}
						crop="fill"
						gravity="auto"
						loading="lazy"
						class="w-full h-full min-h-[400px] object-cover"
					/>
				</div>
				<!-- Mobile image — below content -->
				<div class="rounded-xl overflow-hidden shadow-lg lg:hidden">
					<CloudinaryImage
						publicId="Animals/solar-grazing/IMG_3679_dkimqi"
						alt="Sheep grazing under solar panels at Soul Miner's Eden"
						width={600}
						height={400}
						crop="fill"
						gravity="auto"
						loading="lazy"
						class="w-full h-64 object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- Material Calculator -->
	<section class="section bg-warm-50">
		<div class="container-custom">
			<MaterialCalculator />
		</div>
	</section>

	<!-- Trust & Social Proof -->
	<section class="bg-white border-t border-secondary-200">
		<div class="container-custom py-12 md:py-16">
			<div class="max-w-5xl mx-auto">
				<!-- Stats -->
				<div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
					<div class="text-center">
						<div class="text-4xl font-bold text-primary-500 mb-1">500+</div>
						<div class="text-sm text-warm-600 font-medium">Cubic Yards Monthly</div>
					</div>
					<div class="text-center">
						<div class="text-4xl font-bold text-primary-500 mb-1">65</div>
						<div class="text-sm text-warm-600 font-medium">Acre Working Farm</div>
					</div>
					<div class="text-center">
						<div class="text-4xl font-bold text-primary-500 mb-1">100%</div>
						<div class="text-sm text-warm-600 font-medium">Regenerative</div>
					</div>
					<div class="text-center">
						<div class="text-4xl font-bold text-primary-500 mb-1">24hr</div>
						<div class="text-sm text-warm-600 font-medium">Delivery Turnaround</div>
					</div>
				</div>

				<!-- Trust badges -->
				<div class="flex flex-wrap justify-center gap-4">
					<span class="trust-badge">Regenerative</span>
					<span class="trust-badge">Naturally Grown</span>
					<span class="trust-badge">Family-Owned</span>
					<span class="trust-badge">Bogart, Georgia</span>
					<span class="trust-badge">A Southland Organics Company</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Experience the Farm Life -->
	<ExperienceFarm />

	<!-- Instagram Feed — Living window into the farm -->
	<InstagramFeed />
</MainLayout>

<style>
	/* Hero section video background styles */
	.hero-section {
		position: relative;
		isolation: isolate;
	}

	.hero-video-wrapper {
		position: absolute;
		inset: 0;
		z-index: -2;
		overflow: hidden;
	}

	.hero-video {
		position: absolute;
		top: 50%;
		left: 50%;
		min-width: 100%;
		min-height: 100%;
		width: auto;
		height: auto;
		transform: translate(-50%, -50%);
		object-fit: cover;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		z-index: -1;
		background-color: rgba(0, 0, 0, 0.5);
	}
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/hls.js@1"></script>
<script is:inline>
	document.addEventListener('DOMContentLoaded', function() {
		var video = document.getElementById('hero-video');
		if (!video) return;

		var streamUrl = video.dataset.streamUrl;
		if (!streamUrl) return;

		if (video.canPlayType('application/vnd.apple.mpegurl')) {
			video.src = streamUrl;
			video.play().catch(function() {});
		} else if (typeof Hls !== 'undefined' && Hls.isSupported()) {
			var hls = new Hls();
			hls.loadSource(streamUrl);
			hls.attachMedia(video);
			hls.on(Hls.Events.MANIFEST_PARSED, function() {
				video.play().catch(function() {});
			});
		}
	});
</script>
