---
/**
 * FarmPhotoGrid Component
 *
 * Cloudinary photo grid that serves as the Instagram feed fallback
 * when real shortcodes haven't been provided yet. Uses the same
 * pillar overline system as InstagramFeed.astro.
 *
 * Once Ayn Parker provides real Instagram shortcodes in
 * data/instagram-feed.json, InstagramFeed will auto-switch
 * to native embeds and this component stops rendering.
 */

import CloudinaryImage from './CloudinaryImage.astro';
import { socialPlatforms, instagramHandle } from '../lib/social';

export interface Props {
  headline?: string;
  subheadline?: string;
  ctaText?: string;
}

const {
  headline = "Follow the Farm",
  subheadline = "Watch the land transform, season by season. Every post is a piece of the journey.",
  ctaText = "Follow @soulminerseden on Instagram",
} = Astro.props;

const instagramUrl = socialPlatforms.instagram.url;

const photos = [
  {
    publicId: "Soul Miner's/bin_1",
    alt: "The grain bin and farm stand at Soul Miner's Eden",
    pillar: "TODAY AT THE STAND",
  },
  {
    publicId: "Soul Miner's/bin_2",
    alt: "The grain bin at Soul Miner's Eden — the heart of the farm",
    pillar: "AROUND THE PAVILION",
  },
  {
    publicId: "Soul Miner's/Animals/IMG_2679_z9f17v",
    alt: "Livestock grazing on regenerative pasture",
    pillar: "ANIMALS & ROTATIONS",
  },
  {
    publicId: "Soul Miner's/Animals/solar-grazing/IMG_3685_dqh8sh",
    alt: "Sheep grazing beneath solar panels at dawn",
    pillar: "SOIL & STORY",
  },
  {
    publicId: "Soul Miner's/Animals/solar-grazing/IMG_3679_dkimqi",
    alt: "Flock moving through a solar installation",
    pillar: "ANIMALS & ROTATIONS",
  },
  {
    publicId: "Soul Miner's/events/D8383ADF-C43D-4C35-9266-7DF1C2C6F7FE_1_102_o_uehxcw",
    alt: "Farm-to-table dinner spread at Soul Miner's Eden",
    pillar: "DINNERS & EVENTS",
  },
];
---

<section class="py-16 md:py-24 bg-warm-50" aria-labelledby="farm-photos-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2
        id="farm-photos-heading"
        class="font-serif italic text-4xl md:text-5xl lg:text-6xl mb-6 text-primary-500 leading-tight"
      >
        {headline}
      </h2>
      <p class="text-lg md:text-xl text-warm-600 max-w-2xl mx-auto leading-relaxed">
        {subheadline}
      </p>
    </div>

    <!-- Photo Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {photos.map((photo) => (
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-xl overflow-hidden border border-warm-200 bg-white shadow-sm hover:shadow-md transition-shadow duration-200"
        >
          <div class="px-4 pt-3 pb-1">
            <span class="text-[0.65rem] font-semibold tracking-[0.15em] text-primary-500 uppercase">
              {photo.pillar}
            </span>
          </div>
          <div class="aspect-square overflow-hidden">
            <CloudinaryImage
              publicId={photo.publicId}
              alt={photo.alt}
              width={400}
              height={400}
              crop="fill"
              gravity="auto"
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
        </a>
      ))}
    </div>

    <!-- Follow CTA -->
    <div class="text-center">
      <a
        href={instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-warm-900 hover:bg-warm-800 text-white font-semibold text-lg px-10 py-4 rounded-full transition-colors"
        aria-label={`Follow ${instagramHandle} on Instagram — opens in new tab`}
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.88 0 1.441 1.441 0 012.88 0z"/>
        </svg>
        {ctaText}
      </a>
    </div>
  </div>
</section>
