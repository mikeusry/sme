---
/**
 * Footer Component
 * Matches soulminerseden.com footer structure
 * Source: Live site crawl + business-info.json
 */

import { getSocialPlatformsArray, socialIconPaths } from '../lib/social';

const currentYear = new Date().getFullYear();
const socialLinks = getSocialPlatformsArray();

const businessInfo = {
  name: "Soul Miner's Eden",
  address: {
    street: "189 Luke Road",
    city: "Bogart",
    state: "GA",
    zip: "30622"
  },
  phone: "(706) 613-4415",
  phoneHref: "tel:+17066134415",
  email: "info@soulminerseden.com",
};

const footerLinks = {
  landscapeSupplies: [
    { label: "Compost", href: "/products/compost" },
    { label: "Topsoil", href: "/products/topsoil" },
    { label: "Natural Mulch", href: "/products/double-ground-hardwood-mulch" },
    { label: "Pine Bark Mulch", href: "/products/pine-bark-mulch" },
    { label: "Brown Mulch", href: "/products/brown-mulch" },
    { label: "Black Mulch", href: "/products/black-mulch" },
    { label: "Red Mulch", href: "/products/red-mulch" },
    { label: "Wood Chips", href: "/products/wood-chips" },
    { label: "Sod Soil", href: "/products/sod-soil" },
    { label: "Bioretention Soil", href: "/products/bioretention-soil" },
    { label: "Used Artificial Turf", href: "/products/used-artificial-turf" },
  ],
  resources: [
    { label: "FAQs", href: "/resources/faq" },
    { label: "Plant Care Guides", href: "/blog" },
    { label: "Sustainability", href: "/about" },
  ],
  support: [
    { label: "Contact Us", href: "/contact" },
    { label: "Delivery Info", href: "/resources/delivery" },
  ],
  company: [
    { label: "Our Story", href: "/about" },
    { label: "Sustainable Farming", href: "/about" },
    { label: "Visit Us", href: "/contact" },
  ]
};
---

<footer class="bg-warm-900 text-warm-300">
  <div class="container-custom py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10">
      <!-- Logo & Contact Info -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-6">
          <img
            src="https://cdn.prod.website-files.com/5f402c152dc0917b4df7ee70/677ffdc1b10cad976577364a_Soul%20Miner_s%20Eden%20Primary%20Logo%20Vector%20CMYK.svg"
            alt="Soul Miner's Eden"
            class="h-12 w-auto brightness-0 invert"
          />
        </a>

        <div class="space-y-3 text-sm">
          <p class="flex items-start gap-2">
            <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>
              {businessInfo.address.street}<br />
              {businessInfo.address.city}, {businessInfo.address.state} {businessInfo.address.zip}
            </span>
          </p>
          <p>
            <a href={businessInfo.phoneHref} class="flex items-center gap-2 hover:text-primary-400 transition-colors">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {businessInfo.phone}
            </a>
          </p>
          <p>
            <a href={`mailto:${businessInfo.email}`} class="flex items-center gap-2 hover:text-primary-400 transition-colors">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {businessInfo.email}
            </a>
          </p>
        </div>

        <!-- Social Links -->
        <div class="flex gap-4 mt-6">
          {socialLinks.map(platform => (
            <a
              href={platform.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-warm-400 hover:text-primary-400 transition-colors"
              aria-label={platform.ariaLabel}
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d={socialIconPaths[platform.key]} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Landscape Supplies -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Landscape Supplies</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.landscapeSupplies.map(link => (
            <li>
              <a href={link.href} class="hover:text-primary-400 transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Resources</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.resources.map(link => (
            <li>
              <a href={link.href} class="hover:text-primary-400 transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Support</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.support.map(link => (
            <li>
              <a href={link.href} class="hover:text-primary-400 transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Company</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.company.map(link => (
            <li>
              <a href={link.href} class="hover:text-primary-400 transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-warm-800">
    <div class="container-custom py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
        <p class="text-warm-500">
          &copy; {currentYear} Soul Miner's Eden. All rights reserved.
        </p>
        <div class="flex flex-wrap justify-center gap-6 text-warm-500">
          <a href="/privacy" class="hover:text-primary-400 transition-colors">Privacy Policy</a>
          <a href="/terms" class="hover:text-primary-400 transition-colors">Terms of Service</a>
          <a href="/cookies" class="hover:text-primary-400 transition-colors">Cookies Settings</a>
        </div>
      </div>
    </div>
  </div>
</footer>
