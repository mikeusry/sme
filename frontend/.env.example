# Soul Miner's Eden Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# Medusa Backend (Required)
# ============================================================================
PUBLIC_MEDUSA_BACKEND_URL=https://backend-production-2bafd.up.railway.app
PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_a503cb83700c8aead31f0bd42cd213ca12f7870f6922831c7f48bdf37748b877
MEDUSA_BACKEND_URL=https://backend-production-2bafd.up.railway.app

# Admin API Access (Required for /admin/orders)
# Create admin user in Medusa backend first
MEDUSA_ADMIN_EMAIL=admin@soulminerseden.com
MEDUSA_ADMIN_PASSWORD=your_admin_password_here

# ============================================================================
# Stripe (Required for Payments)
# ============================================================================
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# ============================================================================
# Cloudinary (Required for Images)
# ============================================================================
PUBLIC_CLOUDINARY_CLOUD_NAME=southland-organics
PUBLIC_CLOUDINARY_API_KEY=246196521633339
CLOUDINARY_API_SECRET=vQLdl6oOHdhvLgQqC8CnfqAxjAY
PUBLIC_CLOUDINARY_FOLDER=Soul Miner's/

# ============================================================================
# Supabase (Optional - for analytics/admin features)
# ============================================================================
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# ============================================================================
# Site Configuration
# ============================================================================
PUBLIC_SITE_NAME=Soul Miner's Eden
PUBLIC_SITE_URL=https://soulminerseden.com

# ============================================================================
# Email Notifications (Optional - choose one provider)
# ============================================================================

# Option 1: SendGrid
# SENDGRID_API_KEY=SG....
# SENDGRID_FROM_EMAIL=orders@soulminerseden.com

# Option 2: Resend
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=orders@soulminerseden.com

# Option 3: SMTP (any provider)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=orders@soulminerseden.com

# ============================================================================
# MUX Video (Optional - for video backgrounds)
# ============================================================================
# MUX_TOKEN_ID=...
# MUX_TOKEN_SECRET=...

# ============================================================================
# Development Settings
# ============================================================================
# For local development, use localhost:
# PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# PUBLIC_SITE_URL=http://localhost:4321
